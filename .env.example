# ============================================
# AJ SUITE — ENVIRONMENT VARIABLES
# Copy this file, rename to .env.local
# Fill in your values below
# NEVER commit .env.local to git
# ============================================

# Supabase — get from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=paste_your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=paste_your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=paste_your_service_role_key_here

# Groq — get from console.groq.com
GROQ_API_KEY=paste_your_groq_key_here

# Paystack — get from dashboard.paystack.com > Settings > API
PAYSTACK_SECRET_KEY=paste_your_paystack_secret_key_here

# Pricing — fill in when ready (amounts in Kobo: ₦1000 = 100000)
# SOLO_PLAN_PRICE=INSERT_SOLO_PRICE_HERE
# CHAMBER_PLAN_PRICE=INSERT_CHAMBER_PRICE_HERE
